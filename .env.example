# Strava API Credentials
# Get these from https://www.strava.com/settings/api
# 
# SECURITY WARNING:
# - Never commit the actual .env file to git
# - Keep your credentials private
# - Rotate credentials if exposed
# - The .env file is gitignored by default

STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Optional: Token encryption key (will be auto-generated if not provided)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TOKEN_ENCRYPTION_KEY=your_encryption_key_here

# Production server settings (gunicorn)
APP_PORT=8083
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
LOG_LEVEL=info

# ntfy.sh Push Notifications
# Get your unique topic from https://ntfy.sh or use a self-hosted server
# Generate unique topic: python3 -c "import uuid; print(f'ride-optimizer-{uuid.uuid4().hex[:8]}')"
NTFY_ENABLED=false
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=ride-optimizer-your-unique-id
NTFY_PRIORITY_CRITICAL=urgent
NTFY_PRIORITY_WARNING=high
NTFY_PRIORITY_INFO=default
NTFY_THROTTLE_HOURS=6